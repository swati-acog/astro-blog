---
interface Props {
  title: string;
  description?: string;
}
const { title, description = "Developer Portfolio" } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <slot name="head" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,600;1,8..60,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="site-header-inner">
        <div class="brand-wrap">
          <a href="/" class="brand">Agan<span>itha</span></a>
          <nav class="header-nav">
            <a href="/blogs" class="nav-link">Blogs</a>
            <a href="/directory" class="nav-link">Directory</a>
          </nav>
        </div>
        <div class="header-search" id="headerSearch">
          <svg class="hdr-search-icon" width="16" height="16" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.9">
            <circle cx="9" cy="9" r="6"/><path d="M15 15l3 3"/>
          </svg>
          <input
            id="hdrSearchInput"
            type="text"
            placeholder="Search…"
            autocomplete="off"
            spellcheck="false"
            aria-label="Search"
          />
          <button id="hdrClearBtn" class="hdr-clear-btn" aria-label="Clear" style="display:none">
            <svg width="12" height="12" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M1 1l12 12M13 1L1 13"/>
            </svg>
          </button>
          <div id="hdrResults" class="hdr-results" role="listbox"></div>
        </div>
      </div>
    </header>
    <main class="page-content">
      <slot />
    </main>
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --color-bg: #FAFAF8;
    --color-surface: #FFFFFF;
    --color-surface-raised: #FFFFFF;
    --color-border: #EBEBEA;
    --color-primary: #1C1917;
    --color-primary-light: #6B7280;
    --color-accent: #7C3AED;
    --color-accent-mid: #6D28D9;
    --color-accent-light: #EDE9FE;
    --color-tag-bg: #F5F3FF;
    --color-text: #1C1917;
    --color-text-muted: #6B7280;
    --color-text-subtle: #9CA3AF;
    --radius-sm: 4px;
    --radius-md: 8px;
    --radius-lg: 14px;
    --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
    --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.05);
    --shadow-lg: 0 12px 24px rgba(0, 0, 0, 0.1);
    --font-sans: 'DM Sans', system-ui, sans-serif;
    --font-serif: 'Source Serif 4', Georgia, serif;
  }

  html {
    font-family: var(--font-sans);
    background-color: var(--color-bg);
    color: var(--color-text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
  }

  body {
    min-height: 100vh;
    padding-top: 60px; /* Space for the fixed header */
    overflow-x: hidden;
  }

  /* ── Site Header ── */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 60px;
    background: rgba(250, 250, 248, 0.85);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border);
    z-index: 1000;
  }

  .site-header-inner {
    max-width: 1000px;
    height: 100%;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .brand-wrap {
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .header-nav {
    display: flex;
    gap: 1.5rem;
    margin-left: 0.5rem;
    border-left: 1px solid var(--color-border);
    padding-left: 1.5rem;
  }

  .nav-link {
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .nav-link:hover {
    color: var(--color-accent);
  }

  .brand {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    font-weight: 600;
    color: var(--color-primary) !important;
    letter-spacing: -0.03em;
  }

  .brand span {
    color: var(--color-accent);
  }

  /* ── Inline header search ── */
  .header-search {
    position: relative;
    display: flex;
    align-items: center;
    gap: 6px;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    padding: 5px 10px;
    width: 140px;
    transition: width 0.25s ease, border-color 0.15s, box-shadow 0.15s;
  }

  .header-search:focus-within {
    width: 280px;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.1);
  }

  .hdr-search-icon {
    color: var(--color-text-subtle);
    flex-shrink: 0;
    pointer-events: none;
  }

  #hdrSearchInput {
    flex: 1;
    border: none;
    background: transparent;
    outline: none;
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-text);
    min-width: 0;
  }

  #hdrSearchInput::placeholder {
    color: var(--color-text-subtle);
  }

  .hdr-clear-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    padding: 2px;
    color: var(--color-text-subtle);
    border-radius: 50%;
    flex-shrink: 0;
    transition: color 0.15s;
  }

  .hdr-clear-btn:hover { color: var(--color-text); }

  .hdr-results {
    display: none;
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    width: 400px;
    max-height: 480px;
    overflow-y: auto;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.12);
    z-index: 2000;
    padding: 6px;
  }

  .hdr-results.open { display: block; }

  .hdr-result-item {
    display: block;
    text-decoration: none;
    color: inherit;
    padding: 10px 12px;
    border-radius: 8px;
    transition: background 0.1s;
  }

  .hdr-result-item:hover,
  .hdr-result-item.active { background: var(--color-tag-bg); }

  .hdr-result-section {
    font-family: var(--font-sans);
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--color-accent);
    margin-bottom: 2px;
  }

  .hdr-result-title {
    font-family: var(--font-serif);
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.3;
    margin-bottom: 3px;
  }

  .hdr-result-excerpt {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .hdr-result-excerpt mark {
    background: #EDE9FE;
    color: var(--color-accent);
    border-radius: 2px;
    padding: 0 2px;
  }

  .hdr-no-results {
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    text-align: center;
    padding: 1.5rem 1rem;
  }

  .hdr-footer {
    font-family: var(--font-sans);
    font-size: 0.6875rem;
    color: var(--color-text-subtle);
    text-align: center;
    padding: 6px 4px 2px;
    border-top: 1px solid var(--color-border);
    margin-top: 4px;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  a {
    color: var(--color-primary);
    text-decoration: none;
    transition: color 0.2s;
  }

  a:hover {
    color: var(--color-accent);
  }

  h1, h2, h3, h4 {
    font-family: var(--font-serif);
    line-height: 1.25;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-primary);
  }
</style>

<script>
  // ── Inline header search (raw Pagefind API — no widget flicker) ──
  let pf: any = null;
  let pfLoading = false;
  let debounceTimer: ReturnType<typeof setTimeout>;
  let activeIdx = -1;

  const input    = document.getElementById('hdrSearchInput') as HTMLInputElement;
  const clearBtn = document.getElementById('hdrClearBtn') as HTMLButtonElement;
  const panel    = document.getElementById('hdrResults') as HTMLDivElement;

  async function loadPagefind() {
    if (pf || pfLoading) return;
    pfLoading = true;
    try {
      // Dynamic import via Function to avoid TS resolving the build-time path
      const importFn = new Function('path', 'return import(path)');
      pf = await importFn('/pagefind/pagefind.js');
      await pf.init();
    } catch {
      // Pagefind only available after build
    }
    pfLoading = false;
  }

  function getItems() {
    return Array.from(panel.querySelectorAll<HTMLAnchorElement>('.hdr-result-item'));
  }

  function setActive(idx: number) {
    const items = getItems();
    items.forEach((el, i) => el.classList.toggle('active', i === idx));
    activeIdx = idx;
  }

  function closePanel() {
    panel.classList.remove('open');
    panel.innerHTML = '';
    activeIdx = -1;
  }

  async function doSearch(q: string) {
    if (!q.trim()) { closePanel(); return; }
    if (!pf) { return; }

    const res  = await pf.search(q);
    const data = await Promise.all(res.results.slice(0, 8).map((r: any) => r.data()));

    if (!data.length) {
      panel.innerHTML = `<div class="hdr-no-results">No results for "<strong>${q}</strong>"</div>`;
    } else {
      panel.innerHTML =
        data.map((r: any) => `
          <a class="hdr-result-item" href="${r.url ?? '#'}">
            ${r.meta?.section ? `<div class="hdr-result-section">${r.meta.section}</div>` : ''}
            <div class="hdr-result-title">${r.meta?.title ?? 'Untitled'}</div>
            ${r.excerpt ? `<div class="hdr-result-excerpt">${r.excerpt}</div>` : ''}
          </a>`).join('') +
        (res.results.length > 8
          ? `<div class="hdr-footer">${res.results.length - 8} more results</div>`
          : '');
    }
    panel.classList.add('open');
    activeIdx = -1;
  }

  // Load Pagefind on first focus
  input.addEventListener('focus', loadPagefind, { once: true });

  input.addEventListener('input', () => {
    clearBtn.style.display = input.value ? 'flex' : 'none';
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => doSearch(input.value), 200);
  });

  // Keyboard navigation
  input.addEventListener('keydown', (e) => {
    const items = getItems();
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      setActive(Math.min(activeIdx + 1, items.length - 1));
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      setActive(Math.max(activeIdx - 1, 0));
    } else if (e.key === 'Enter' && activeIdx >= 0) {
      e.preventDefault();
      items[activeIdx]?.click();
    } else if (e.key === 'Escape') {
      clearBtn.click();
    }
  });

  clearBtn.addEventListener('click', () => {
    input.value = '';
    clearBtn.style.display = 'none';
    closePanel();
    input.focus();
  });

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (!document.getElementById('headerSearch')?.contains(e.target as Node)) {
      closePanel();
    }
  });
</script>
