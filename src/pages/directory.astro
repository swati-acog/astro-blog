---
import { getUsers } from "../lib/content";
import PortfolioLayout from "../layouts/PortfolioLayout.astro";

const users = await getUsers();

// Stats
const withEmail   = users.filter(u => u.email).length;
const withPhone   = users.filter(u => u.phone).length;
const withTitle   = users.filter(u => u.title).length;
---

<PortfolioLayout title="Employee Directory — Aganitha" description="Contact directory for all Aganitha team members.">
  <main class="dir-page">
    <div class="dir-wrap">

      <!-- Header -->
      <div class="dir-header">
        <div class="dir-header-left">
          <h1>Employee <em>Directory</em></h1>
          <p>Name, email and contact extracted from each member's profile.</p>
        </div>
        <!-- <div class="backend-note">
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.6">
            <rect x="2" y="3" width="12" height="10" rx="2"/>
            <path d="M5 7h6M5 10h4"/>
          </svg>
          Read-only · synced from profiles
        </div> -->
      </div>

      <!-- Stats -->
      <div class="dir-stats">
        <div class="dir-stat">
          <div class="dir-stat-icon">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6">
              <circle cx="8" cy="6" r="3"/><circle cx="14" cy="6" r="3"/>
              <path d="M2 18c0-3.3 2.7-6 6-6s6 2.7 6 6"/><path d="M10 13.2C11 12.4 12.4 12 14 12c3.3 0 6 2.7 6 6"/>
            </svg>
          </div>
          <div>
            <div class="dir-stat-num">{users.length}</div>
            <div class="dir-stat-label">Total members</div>
          </div>
        </div>
        <div class="dir-stat">
          <div class="dir-stat-icon">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6">
              <rect x="2" y="4" width="16" height="12" rx="2"/><path d="M2 7l8 5 8-5"/>
            </svg>
          </div>
          <div>
            <div class="dir-stat-num">{withEmail}</div>
            <div class="dir-stat-label">With email</div>
          </div>
        </div>
        <div class="dir-stat">
          <div class="dir-stat-icon">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6">
              <path d="M3 4a1 1 0 011-1h3l1.5 4-2 1a11 11 0 005 5l1-2 4 1.5V16a1 1 0 01-1 1C8.2 17 3 11.8 3 5V4z"/>
            </svg>
          </div>
          <div>
            <div class="dir-stat-num">{withPhone}</div>
            <div class="dir-stat-label">With phone</div>
          </div>
        </div>
        <div class="dir-stat">
          <div class="dir-stat-icon">
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.6">
              <rect x="3" y="2" width="14" height="18" rx="2"/><path d="M7 7h6M7 10h4"/>
            </svg>
          </div>
          <div>
            <div class="dir-stat-num">{withTitle}</div>
            <div class="dir-stat-label">With title</div>
          </div>
        </div>
      </div>

      <!-- Search bar -->
      <div class="dir-toolbar">
        <div class="dir-search">
          <svg width="15" height="15" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8">
            <circle cx="9" cy="9" r="6"/><path d="M15 15l3 3"/>
          </svg>
          <input type="text" id="dirSearch" placeholder="Search by name, title, location…" />
        </div>
      </div>

      <!-- Table -->
      <div class="dir-table-wrap">
        <table class="dir-table">
          <thead>
            <tr>
              <th>Employee</th>
              <th>Email</th>
              <th>Phone</th>
              <!-- <th>Location</th> -->
              <th>Profile</th>
            </tr>
          </thead>
          <tbody id="dirTableBody">
            {users.map(user => (
              <tr class="dir-row" data-name={(user.name ?? '').toLowerCase()} data-title={(user.title ?? '').toLowerCase()} data-location={`${user.location?.city ?? ''} ${user.location?.country ?? ''}`.toLowerCase()}>
                <td>
                  <div class="emp-cell">
                    <img src={user.avatar} alt={user.name} width={34} height={34} class="emp-av" />
                    <div>
                      <div class="emp-name">{user.name}</div>
                      {user.title && <div class="emp-role">{user.title}</div>}
                    </div>
                  </div>
                </td>
                <td>
                  {user.email
                    ? <a class="email-link" href={`mailto:${user.email}`}>{user.email}</a>
                    : <span class="nil">—</span>}
                </td>
                <td>
                  {user.phone
                    ? <span class="phone-text">{user.phone}</span>
                    : <span class="nil">—</span>}
                </td>
                {/* <td>
                  {user.location
                    ? <span class="location-text">{user.location.city}, {user.location.country}</span>
                    : <span class="nil">—</span>}
                </td> */}
                <td>
                  <a href={`/users/${user.id}`} class="profile-link">View →</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
        <div class="empty-state" id="emptyState" style="display:none">
          <svg width="36" height="36" viewBox="0 0 40 40" fill="none" stroke="currentColor" stroke-width="1.4">
            <circle cx="20" cy="14" r="7"/><path d="M6 36c0-7.7 6.3-14 14-14s14 6.3 14 14"/>
          </svg>
          <p>No members match your search.</p>
        </div>
      </div>

    </div>
  </main>
</PortfolioLayout>

<script>
  const input = document.getElementById('dirSearch') as HTMLInputElement;
  const rows  = document.querySelectorAll<HTMLTableRowElement>('.dir-row');
  const empty = document.getElementById('emptyState')!;

  input?.addEventListener('input', () => {
    const q = input.value.trim().toLowerCase();
    let visible = 0;
    rows.forEach(row => {
      const matches = !q
        || row.dataset.name!.includes(q)
        || row.dataset.title!.includes(q)
        || row.dataset.location!.includes(q);
      row.style.display = matches ? '' : 'none';
      if (matches) visible++;
    });
    empty.style.display = visible === 0 ? 'block' : 'none';
  });
</script>

<style>
  .dir-page { padding: 3rem 0 6rem; }

  .dir-wrap {
    max-width: 1060px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ── Header ── */
  .dir-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .dir-header-left h1 {
    font-family: var(--font-serif);
    font-size: 2.25rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    margin-bottom: 0.35rem;
  }

  .dir-header-left h1 em {
    font-style: italic;
    color: var(--color-accent);
  }

  .dir-header-left p {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .backend-note {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: color-mix(in srgb, var(--color-accent) 8%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-accent) 25%, transparent);
    border-radius: var(--radius-md);
    padding: 0.5rem 0.875rem;
    font-size: 0.75rem;
    color: var(--color-accent);
    font-weight: 500;
    white-space: nowrap;
  }

  /* ── Stats ── */
  .dir-stats {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .dir-stat {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 0.875rem 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex: 1;
    min-width: 130px;
  }

  .dir-stat-icon {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--color-accent);
  }

  .dir-stat-num {
    font-family: var(--font-serif);
    font-size: 1.625rem;
    font-weight: 400;
    line-height: 1;
    color: var(--color-text);
    letter-spacing: -0.03em;
  }

  .dir-stat-label {
    font-size: 0.6875rem;
    color: var(--color-text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-top: 0.2rem;
  }

  /* ── Toolbar ── */
  .dir-toolbar {
    margin-bottom: 1.25rem;
  }

  .dir-search {
    position: relative;
    max-width: 380px;
  }

  .dir-search svg {
    position: absolute;
    left: 11px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-text-subtle);
    pointer-events: none;
  }

  .dir-search input {
    width: 100%;
    padding: 0.55rem 0.75rem 0.55rem 2.25rem;
    border: 1px solid var(--color-border);
    border-radius: 100px;
    background: var(--color-surface);
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    color: var(--color-text);
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .dir-search input::placeholder { color: var(--color-text-subtle); }

  .dir-search input:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-accent) 12%, transparent);
  }

  /* ── Table ── */
  .dir-table-wrap {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  .dir-table {
    width: 100%;
    border-collapse: collapse;
  }

  .dir-table thead {
    background: color-mix(in srgb, var(--color-accent) 6%, var(--color-bg));
  }

  .dir-table th {
    padding: 0.75rem 1.25rem;
    text-align: left;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    border-bottom: 1px solid var(--color-border);
    font-family: var(--font-sans);
  }

  .dir-table td {
    padding: 0.875rem 1.25rem;
    font-size: 0.875rem;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text);
    vertical-align: middle;
  }

  .dir-table tr:last-child td { border-bottom: none; }

  .dir-table tbody tr {
    transition: background 0.12s;
  }

  .dir-table tbody tr:hover td {
    background: color-mix(in srgb, var(--color-accent) 3%, transparent);
  }

  /* ── Cells ── */
  .emp-cell {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .emp-av {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
    border: 1px solid var(--color-border);
  }

  .emp-name {
    font-weight: 600;
    font-size: 0.875rem;
    color: var(--color-text);
  }

  .emp-role {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: 1px;
  }

  .email-link {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
  }

  .email-link:hover { text-decoration: underline; }

  .phone-text {
    color: var(--color-text-muted);
    font-size: 0.8125rem;
  }

  .location-text {
    color: var(--color-text-muted);
    font-size: 0.8125rem;
  }

  .nil { color: var(--color-text-subtle); }

  .profile-link {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    white-space: nowrap;
  }

  .profile-link:hover { text-decoration: underline; }

  /* ── Empty state ── */
  .empty-state {
    text-align: center;
    padding: 4rem 1.5rem;
    color: var(--color-text-muted);
  }

  .empty-state svg {
    display: block;
    margin: 0 auto 1rem;
    color: var(--color-text-subtle);
  }

  .empty-state p {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.125rem;
  }

  @media (max-width: 640px) {
    .dir-header { flex-direction: column; align-items: flex-start; }
    .backend-note { display: none; }
    .dir-stats { gap: 0.5rem; }
    .dir-stat { min-width: 120px; }
  }
</style>
