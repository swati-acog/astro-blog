---
import { getAllBlogPosts, getUsers } from "../lib/content";
import PortfolioLayout from "../layouts/PortfolioLayout.astro";
import BlogPostCard from "../components/BlogPostCard.astro";

const allPosts = await getAllBlogPosts();
const allUsers = await getUsers();

const authorMap = Object.fromEntries(
  allUsers.map(user => [user.id, { name: user.name, avatar: user.avatar }])
);
---

<PortfolioLayout title="Team Blogs" description="The latest insights and updates from our entire team.">
  <main class="blogs-page">
    <div class="container">
      <header class="feed-hero">
        <h1>Where great ideas find their <em>voice</em></h1>
        <p>Insights, reflections, and deep-dives from across the organisation.</p>
      </header>

      <div class="blogs-grid">
        {allPosts.map((post, i) => {
          const authors = [post.userId, ...(post.coAuthors ?? [])]
            .map(id => authorMap[id])
            .filter(Boolean);
          return (
            <BlogPostCard
              title={post.title}
              date={post.date}
              description={post.description}
              tags={post.tags}
              href={`/users/${post.userId}/blog/${post.slug}`}
              authors={authors}
              colorIndex={i}
            />
          );
        })}
      </div>
    </div>
  </main>
</PortfolioLayout>

<style>
  .blogs-page {
    padding: 0 0 6rem;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .feed-hero {
    padding: 52px 0 20px;
  }

  .feed-hero h1 {
    font-family: var(--font-serif);
    font-size: 2.75rem;
    font-weight: 400;
    line-height: 1.18;
    letter-spacing: -0.5px;
    margin-bottom: 0.75rem;
  }

  .feed-hero h1 em {
    font-style: italic;
    color: var(--color-accent);
  }

  .feed-hero p {
    color: var(--color-text-muted);
    font-size: 1rem;
    max-width: 480px;
    font-family: var(--font-sans);
    line-height: 1.6;
  }

  .blogs-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  @media (max-width: 640px) {
    .blogs-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
