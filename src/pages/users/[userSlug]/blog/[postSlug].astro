---
import { getUsers, getAllBlogPosts } from "../../../../lib/content";
import type { User, BlogPost } from "../../../../lib/content";
import PortfolioLayout from "../../../../layouts/PortfolioLayout.astro";
import { marked } from "marked";

export async function getStaticPaths() {
  const [users, allPosts] = await Promise.all([getUsers(), getAllBlogPosts()]);
  const userMap = Object.fromEntries(users.map(u => [u.id, u]));
  return allPosts.map(post => ({
    params: { userSlug: post.userId, postSlug: post.slug },
    props: { post, userMap },
  }));
}

interface Props {
  post: BlogPost;
  userMap: Record<string, User>;
}
const { post, userMap } = Astro.props;
const { userSlug } = Astro.params;

const primaryAuthor = userMap[userSlug!];
if (!primaryAuthor) return Astro.redirect("/404");

const allAuthors = [userSlug!, ...(post.coAuthors ?? [])]
  .map(id => userMap[id])
  .filter(Boolean);

const htmlContent = await marked.parse(post.body);

const formatted = post.date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<PortfolioLayout
  title={`${post.title} — ${allAuthors.map(a => a.name).join(', ')}`}
  description={post.description ?? `A blog post by ${allAuthors.map(a => a.name).join(' & ')}`}
>
  <main>
    <div class="container">
      <nav class="breadcrumb">
        <a href="/">← all profiles</a>
        <span class="sep">/</span>
        <a href={`/users/${userSlug}`}>{primaryAuthor.name}</a>
        <span class="sep">/</span>
        <span class="current">Blog</span>
      </nav>

      <article class="post">
        <header class="post-header">
          {post.tags && (
            <div class="tags">
              {post.tags.map(tag => <span class="tag">#{tag}</span>)}
            </div>
          )}
          <h1 class="title">{post.title}</h1>
          <div class="meta">
            <div class="authors-byline">
              {allAuthors.map((author, i) => (
                <>
                  {i > 0 && <span class="byline-sep">{i === allAuthors.length - 1 ? ' & ' : ', '}</span>}
                  <a href={`/users/${author.id}`} class="author-link">
                    <img src={author.avatar} alt={author.name} width={20} height={20} class="byline-avatar" />
                    {author.name}
                  </a>
                </>
              ))}
            </div>
            <span class="dot">·</span>
            <time datetime={post.date.toISOString()}>{formatted}</time>
          </div>
        </header>

        <div class="prose" set:html={htmlContent} />

        <footer class="post-footer">
          <a href={`/users/${userSlug}`} class="back-link">
            Back to {primaryAuthor.name}'s profile
          </a>
        </footer>
      </article>
    </div>
  </main>
</PortfolioLayout>

<style>
  main {
    padding-bottom: 5rem;
  }

  .container {
    max-width: 740px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 2.5rem 0 3rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
  }

  .breadcrumb a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .breadcrumb a:hover {
    color: var(--color-accent);
  }

  .breadcrumb .sep {
    color: var(--color-text-subtle);
  }

  .breadcrumb .current {
    color: var(--color-text-subtle);
  }

  .post-header {
    margin-bottom: 3rem;
  }

  .tags {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .tag {
    font-size: 0.875rem;
    color: var(--color-accent);
    font-family: var(--font-sans);
    font-weight: 500;
  }

  .title {
    font-family: var(--font-serif);
    font-size: 2.75rem;
    font-weight: 600;
    color: #292929;
    margin-bottom: 1rem;
    line-height: 1.18;
    letter-spacing: -0.02em;
  }

  .meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1rem;
    color: var(--color-text-muted);
    font-family: var(--font-sans);
    flex-wrap: wrap;
  }

  .authors-byline {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.25rem;
  }

  .author-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    color: var(--color-text);
    font-weight: 500;
    text-decoration: none;
    transition: color 0.2s;
  }

  .author-link:hover {
    color: var(--color-accent);
  }

  .byline-avatar {
    width: 20px;
    height: 20px;
    border-radius: 50%;
    object-fit: cover;
  }

  .byline-sep {
    color: var(--color-text-muted);
  }

  .dot {
    color: var(--color-text-subtle);
  }

  .prose {
    font-family: var(--font-serif);
    font-size: 1.3125rem;
    line-height: 1.58;
    color: #292929;
    letter-spacing: -0.003em;
  }

  .prose :global(p) {
    margin-bottom: 2rem;
  }

  .prose :global(h2) {
    font-family: var(--font-serif);
    font-size: 1.75rem;
    font-weight: 600;
    color: #292929;
    margin: 3rem 0 0.75rem;
    line-height: 1.25;
    letter-spacing: -0.016em;
  }

  .prose :global(h3) {
    font-family: var(--font-serif);
    font-size: 1.375rem;
    font-weight: 600;
    color: #292929;
    margin: 2.5rem 0 0.75rem;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .prose :global(strong) {
    font-weight: 600;
    color: #1a1a1a;
  }

  .prose :global(em) {
    font-style: italic;
  }

  .prose :global(blockquote) {
    border-left: 3px solid #292929;
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-style: italic;
    color: #555;
  }

  .prose :global(code) {
    font-family: 'SFMono-Regular', Consolas, monospace;
    font-size: 0.875em;
    background: #f2f2f2;
    padding: 0.1em 0.35em;
    border-radius: 3px;
  }

  .prose :global(pre) {
    background: #f8f8f8;
    border: 1px solid #e8e8e8;
    border-radius: 6px;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin: 2rem 0;
  }

  .prose :global(pre code) {
    background: none;
    padding: 0;
    font-size: 0.9rem;
    line-height: 1.6;
  }

  .prose :global(img) {
    display: block;
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-md);
    margin: 2rem auto;
  }

  .post-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 500;
  }

  .back-link:hover {
    text-decoration: underline;
  }
</style>
