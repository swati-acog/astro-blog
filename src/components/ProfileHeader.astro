---
interface Social {
  github?: string;
  linkedin?: string;
}

interface Props {
  name: string;
  avatar: string;
  title?: string;
  bio?: string;
  email?: string;
  phone?: string;
  location?: { city: string; country: string };
  social?: Social;
}

const { name, title, bio, email, phone, location, avatar, social } = Astro.props;
---

<div class="profile-header">
  <div class="header-main">
    <div class="details">
      <h1 class="name">{name}</h1>
      {title && <p class="title">{title}</p>}
      {bio && <p class="bio">{bio}</p>}
      
      {(email || phone || location) && (
        <div class="contact-grid">
          {email && (
            <a href={`mailto:${email}`} class="contact-item">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><path d="M3 4a2 2 0 00-2 2v1.161l8.441 4.221a1.25 1.25 0 001.118 0L19 7.162V6a2 2 0 00-2-2H3z"/><path d="M19 8.839l-7.77 3.885a2.75 2.75 0 01-2.46 0L1 8.839V14a2 2 0 002 2h14a2 2 0 002-2V8.839z"/></svg>
              {email}
            </a>
          )}
          {phone && (
            <span class="contact-item">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><path fill-rule="evenodd" d="M2 3.5A1.5 1.5 0 013.5 2h1.148a1.5 1.5 0 011.465 1.175l.716 3.223a1.5 1.5 0 01-1.052 1.767l-.933.267c-.41.117-.643.555-.48.95a11.542 11.542 0 006.254 6.254c.395.163.833-.07.95-.48l.267-.933a1.5 1.5 0 011.767-1.052l3.223.716A1.5 1.5 0 0118 16.352V17.5a1.5 1.5 0 01-1.5 1.5H15c-1.149 0-2.263-.15-3.326-.43A13.022 13.022 0 012.43 8.326 13.019 13.019 0 012 5V3.5z" clip-rule="evenodd"/></svg>
              {phone}
            </span>
          )}
          {location && (
            <span class="contact-item">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" width="14" height="14"><path fill-rule="evenodd" d="M9.69 18.933l.003.001C9.89 19.02 10 19 10 19s.11.02.308-.066l.002-.001.003-.001.003-.001.006-.003.018-.008a5.741 5.741 0 00.281-.14c.186-.096.446-.24.757-.433.62-.384 1.445-.966 2.274-1.765C15.302 15.073 17 12.15 17 9A7 7 0 103 9c0 3.15 1.698 6.073 3.354 7.584a13.731 13.731 0 002.312 1.832c.187.119.35.217.483.288a5.741 5.741 0 00.281.14l.018.008.006.003z" clip-rule="evenodd"/><path fill-rule="evenodd" d="M10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/></svg>
              {location.city}, {location.country}
            </span>
          )}
        </div>
      )}
    </div>
    <div class="avatar-wrap">
      <img src={avatar} alt={`${name}'s profile photo`} width={100} height={100} class="avatar" />
    </div>
  </div>
  {social && (
    <div class="socials">
      {social.github && (
        <a href={social.github} target="_blank" rel="noopener noreferrer" class="social-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="social-icon"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"></path></svg>
          GitHub
        </a>
      )}
      {social.linkedin && (
        <a href={social.linkedin} target="_blank" rel="noopener noreferrer" class="social-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="social-icon"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
          LinkedIn
        </a>
      )}
    </div>
  )}
</div>

<style>
  .profile-header {
    border-bottom: 1px solid var(--color-border);
    padding: 3rem 0;
    margin-bottom: 3rem;
  }

  .header-main {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 3rem;
    margin-bottom: 2rem;
  }

  @media (max-width: 640px) {
    .header-main {
      flex-direction: column-reverse;
      align-items: center;
      text-align: center;
      gap: 2rem;
    }
  }

  .avatar-wrap {
    flex-shrink: 0;
    width: 100px;
    height: 100px;
    border-radius: 50%;
    overflow: hidden;
    background: var(--color-surface);
  }

  .avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .details {
    flex: 1;
  }

  .name {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .title {
    font-family: var(--font-sans);
    font-size: 1.125rem;
    color: var(--color-text-muted);
    font-weight: 500;
    margin-bottom: 1.5rem;
  }

  .bio {
    font-family: var(--font-serif);
    font-size: 1.25rem;
    color: var(--color-text);
    line-height: 1.5;
    margin-bottom: 1.5rem;
    max-width: 60ch;
  }

  .contact-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem 2rem;
    margin-bottom: 1rem;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
    text-decoration: none;
    font-family: var(--font-sans);
  }

  .contact-item svg {
    color: var(--color-text-subtle);
  }

  .socials {
    display: flex;
    gap: 1rem;
  }

  .social-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-sans);
    font-size: 0.875rem;
    color: var(--color-accent);
    text-decoration: none;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    transition: background-color 0.2s, border-color 0.2s;
  }

  .social-link:hover {
    background-color: color-mix(in srgb, var(--color-accent) 5%, transparent);
    border-color: var(--color-accent);
    text-decoration: none;
  }

  .social-icon {
    flex-shrink: 0;
    color: var(--color-accent);
  }
</style>
