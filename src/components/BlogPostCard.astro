---
interface Author {
  name: string;
  avatar: string;
}

interface Props {
  title: string;
  date: Date;
  description?: string;
  tags?: string[];
  href: string;
  authors?: Author[];
  colorIndex?: number;
}

const { title, date, description, tags = [], href, authors = [], colorIndex = 0 } = Astro.props;

const formatted = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const AV_BG    = ['#EDE9FE', '#EFF6FF', '#F0FDF4', '#FFF1F2', '#FFFBEB', '#F5F3FF'];
const AV_COLOR = ['#6D28D9', '#1D4ED8', '#059669', '#DC2626', '#D97706', '#7C3AED'];

function initials(name: string): string {
  return name.split(' ').map(n => n[0]).join('').toUpperCase().slice(0, 2);
}
function avColors(name: string) {
  const i = (name.charCodeAt(0) + (name.charCodeAt(1) || 0)) % AV_BG.length;
  return { bg: AV_BG[i], color: AV_COLOR[i] };
}

const isCollab = authors.length > 1;
const firstTag = tags[0];
---

<a class="blog-card" href={href} data-tags={tags.join(',')}>
  <!-- Card body -->
  <div class="card-body">
    <div class="card-meta">
      <div class="authors-row">
        {authors.map((a, i) => {
          const av = avColors(a.name);
          return (
            <>
              {i > 0 && <span class="collab-sep">&amp;</span>}
              <div class="author-chip">
                <div class="av" style={`background: ${av.bg}; color: ${av.color};`}>
                  {initials(a.name)}
                </div>
                <span class="av-name">{a.name}</span>
              </div>
            </>
          );
        })}
        {isCollab && (
          <span class="collab-badge">
            <svg width="10" height="10" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.6">
              <circle cx="4" cy="4" r="2"/><circle cx="9" cy="4" r="2"/>
              <path d="M1 10c0-1.7 1.3-3 3-3s3 1.3 3 3M7 7.2c.5-.5 1.2-.7 2-.7 1.7 0 3 1.3 3 3"/>
            </svg>
            Collab
          </span>
        )}
      </div>
      <div class="card-date">{formatted}</div>
    </div>

    <div class="card-title">{title}</div>
    {description && <div class="card-excerpt">{description}</div>}

    <div class="card-footer">
      {firstTag
        ? <span class="card-tag">{firstTag}</span>
        : <span />
      }
    </div>
  </div>
</a>

<style>
  .blog-card {
    background: #ffffff;
    border: 1px solid #EBEBEA;
    border-radius: 14px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s, transform 0.15s, border-color 0.2s;
  }

  .blog-card:hover {
    box-shadow: 0 4px 20px rgba(124, 58, 237, 0.10);
    transform: translateY(-3px);
    border-color: #DDD6FE;
  }

  .card-body {
    padding: 22px 24px 24px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .card-meta {
    margin-bottom: 4px;
  }

  .authors-row {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .author-chip {
    display: flex;
    align-items: center;
    gap: 5px;
  }

  .av {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    font-weight: 500;
    flex-shrink: 0;
  }

  .av-name {
    font-size: 14px;
    color: #6B7280;
    font-family: var(--font-sans);
  }

  .collab-sep {
    font-size: 13px;
    color: #9CA3AF;
    margin: 0 2px;
  }

  .collab-badge {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: #EDE9FE;
    color: #7C3AED;
    font-size: 12px;
    font-weight: 500;
    padding: 3px 10px;
    border-radius: 20px;
    margin-left: 4px;
    font-family: var(--font-sans);
  }

  .card-date {
    font-size: 13px;
    color: #9CA3AF;
    margin-top: 6px;
    font-family: var(--font-sans);
  }

  .card-title {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 400;
    line-height: 1.3;
    margin-bottom: 10px;
    margin-top: 12px;
    color: #292929;
    letter-spacing: -0.012em;
  }

  .card-excerpt {
    font-size: 15px;
    color: #6B7280;
    line-height: 1.65;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    font-family: var(--font-sans);
    flex: 1;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 16px;
  }

  .card-tag {
    background: #F5F3FF;
    color: #7C3AED;
    border-radius: 4px;
    padding: 3px 10px;
    font-size: 13px;
    font-weight: 500;
    font-family: var(--font-sans);
  }
</style>
