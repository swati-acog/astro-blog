---
interface Props {
  skill: string;
}
const { skill } = Astro.props;
---

<span class="badge">{skill}</span>

<style>
  .badge {
    display: inline-block;
    font-size: 0.8125rem;
    font-weight: 400;
    padding: 0.25rem 0.75rem;
    background: #f2f2f2;
    color: var(--color-text);
    border-radius: 100px;
    white-space: nowrap;
    font-family: var(--font-sans);
  }
</style>
